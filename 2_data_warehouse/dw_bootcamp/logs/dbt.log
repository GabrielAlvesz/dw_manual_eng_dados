  create  table "dbt_db"."public"."mart_metricas__dbt_tmp"
  
  
    as
  
  (
    

with dim_tempo as (
    select *
    from "dbt_db"."public"."int_dim_tempo"
),

fct_vendas as (
    select *
    from "dbt_db"."public"."int_fct_vendas"
)

-- 01 - Faturamento por mês 
SELECT
    t.ano,
    t.mes,
    t.nome_mes,
    SUM(v.valor_total) AS faturamento
FROM dim_tempo t
LEFT JOIN fct_vendas v
    ON v.sk_tempo = t.sk_tempo
    
where v.status_pedido <> 'Cancelado'    

GROUP BY
    t.ano, t.mes, t.nome_mes
ORDER BY
    t.ano, t.mes
  );
  
